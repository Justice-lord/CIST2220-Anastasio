<Window x:Class="AnastasioP6.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AnastasioP6"
        mc:Ignorable="d"
        Title="Inventory" Height="450" Width="800">
    <!-- Main Grid -->
    <Grid Margin="10">
        
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <!-- Title -->
        <Label Content="Tucker Inventory With UNDO" 
               Grid.Row="0" 
               Grid.Column="0" 
               Grid.ColumnSpan="3" 
               HorizontalAlignment="Center" 
               FontSize="22" 
               FontWeight="Bold"/>
        
        <!-- Label -->
        <Label Content="Enter Item Name" 
               Grid.Row="1" 
               Grid.Column="0"/>
        
        <Label Content="Inventory List" 
               Grid.Row="1" 
               Grid.Column="3"/>
        
        <!-- Item Name textbox -->
        <TextBox x:Name="tbxItemName" 
                 Grid.Row="2" 
                 Grid.Column="0"
                 Margin="0,5"/>
        
        <!-- Inventory List Box -->
        <ListBox x:Name="lbxInventoryList" 
                 Grid.Row="2" 
                 Grid.Column="2" 
                 Grid.RowSpan="5"
                 Margin="0,5,0,0"/>
        
        <!-- Buttons Add, Add Multi, Undo -->
        <Button x:Name="btnAddOne" 
                Content="Add One Item" 
                Grid.Row="3" 
                Grid.Column="0"
                Margin="0,5"
                Click="btnAddOne_Click"/>
        
        <Button x:Name="btnAddMulti" 
                Content="Add Multiple Items" 
                Grid.Row="4" 
                Grid.Column="0"
                Margin="0,5"
                Click="btnAddMulti_Click"/>
        
        <Button x:Name="btnUndo"
                Content="Undo" 
                Grid.Row="5" 
                Grid.Column="0"
                Margin="0,5"
                Click="btnUndo_Click"/>
    </Grid>
</Window>
