<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ExpenseTracker.Views.TransactionsPage"
             Title="Transactions">
    <CollectionView ItemsSource="{Binding Transactions}">
        <CollectionView.ItemTemplate>
            <DataTemplate>
                <SwipeView>
                    <SwipeView.RightItems>
                        <SwipeItems Mode="Reveal">
                            <SwipeItem Text="Delete"
                                       BackgroundColor="Red"
                                       Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteTransactionCommand}"
                                       CommandParameter="{Binding}"/>
                        </SwipeItems>
                    </SwipeView.RightItems>
                    <Border Margin="10" Padding="10">
                        <VerticalStackLayout>
                            <Label Text="{Binding Category}" FontAttributes="Bold"/>
                            <Label Text="{Binding Descrption}"/>
                            <Label Text="{Binding Amount}"/>
                            <Label Text="{Binding Date}"/>
                        </VerticalStackLayout>
                    </Border>
                </SwipeView>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>
</ContentPage>