<Window x:Class="WPFDemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPFDemo"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Label Content="First:" HorizontalAlignment="Left" Margin="100,50,0,0" VerticalAlignment="Top"/>
        <Label Content="Last:" HorizontalAlignment="Left" Margin="100,81,0,0" VerticalAlignment="Top"/>
        <Label Content="Student Num:" HorizontalAlignment="Left" Margin="100,112,0,0" VerticalAlignment="Top"/>
        <Label Content="Major:" HorizontalAlignment="Left" Margin="100,143,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="tbxFirstName" HorizontalAlignment="Left" Margin="206,58,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120"/>
        <TextBox x:Name="tbxLastName" HorizontalAlignment="Left" Margin="206,89,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120"/>
        <TextBox x:Name="tbxStudentNum" HorizontalAlignment="Left" Margin="206,120,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120"/>
        <TextBox x:Name="tbxMajor" HorizontalAlignment="Left" Margin="206,151,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120"/>
        <Button x:Name="btnSubmit" Content="Submit" HorizontalAlignment="Left" Margin="230,197,0,0" VerticalAlignment="Top" Width="72" Click="btnSubmit_Click"/>
        <TextBlock x:Name="txbResults" HorizontalAlignment="Center" Margin="0,350,0,0" TextWrapping="Wrap" Text="TextBlock" VerticalAlignment="Top" Height="74" Width="780"/>
        <ListBox x:Name="lbxCourses" Margin="475,10,10,197"/>
        <Label Content="Course Scores" HorizontalAlignment="Left" Margin="373,111,0,0" VerticalAlignment="Top"/>
        <Button x:Name="btnAdd" Content="Add" HorizontalAlignment="Left" Margin="744,258,0,0" VerticalAlignment="Top" Click="btnAdd_Click" Width="46"/>
        <TextBox x:Name="tbxScore" HorizontalAlignment="Left" Margin="657,259,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="76" Height="22"/>
        <Label Content="Score" HorizontalAlignment="Left" Margin="613,257,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="tbxTitle" HorizontalAlignment="Left" Margin="512,259,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="86" Height="22"/>
        <Label Content="Title" HorizontalAlignment="Left" Margin="475,255,0,0" VerticalAlignment="Top"/>

    </Grid>
</Window>
