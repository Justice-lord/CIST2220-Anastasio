<Window x:Class="WPFDemo.SchoolWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPFDemo"
        mc:Ignorable="d"
        Title="SchoolWindow" Height="450" Width="800">
    <Grid>
        <TabControl HorizontalAlignment="Center" Height="414"
                    VerticalAlignment="Center" Width="780">
            <TabItem Header="Campuses">
                <Grid Background="#FFE5E5E5">
                    <ListBox x:Name="lbxCampuses" HorizontalAlignment="Center" Height="386" VerticalAlignment="Center" Width="774"/>
                </Grid>
            </TabItem>
            <TabItem Header="Majors">
                <Grid Background="#FFE5E5E5">
                    <ListBox x:Name="lbxMajors" HorizontalAlignment="Center" Height="386" VerticalAlignment="Center" Width="774"/>
                </Grid>
            </TabItem>
            <TabItem Width="57.9733333333333" Header="Courses">
                <Grid Background="#FFE5E5E5">
                    <ListBox x:Name="lbxCourses" HorizontalAlignment="Center" Height="386" VerticalAlignment="Center" Width="774"/>
                </Grid>
            </TabItem>
            <TabItem Width="57.9733333333333" Header="Students">
                <Grid Background="#FFE5E5E5">
                    <ListBox x:Name="lbxStudents" HorizontalAlignment="Center" Height="339" VerticalAlignment="Top" Width="774"/>
                    <Button x:Name="btnAddStudent" Content="Add Student" Click="btnAddStudent_Click" Margin="149,351,449,10"/>
                    <Button x:Name="btnSaveStudentList" Content="Save Student List" HorizontalAlignment="Left" Margin="447,351,0,0" VerticalAlignment="Top" Height="25" Width="175" Click="btnSaveStudentList_Click"/>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
