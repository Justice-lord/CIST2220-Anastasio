<Window x:Class="AnastasioP5.SprocketOrderForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AnastasioP5"
        mc:Ignorable="d"
        Title="Sprocket Order Form" 
        Height="450" 
        Width="800">

    <!-- Form -->
    <Grid Margin="20">
        
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Title -->
        <TextBlock Grid.Row="0" 
                   Text="Sprocket Order Manager"
                   FontSize="22"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>
        
        <!-- Inputs -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="35"/>
                <RowDefinition Height="35"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Label Content="Customer Name" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"/>
            <TextBox x:Name="tbxName" Grid.Row="0" Grid.Column="1" Margin="2"/>
            <CheckBox x:Name="chxLocalPickup" Content="Local Pickup?" Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" Click="chxLocalPickup_Click"/>

            <Grid Grid.Row="2" Grid.ColumnSpan="2" x:Name="grdAddress" HorizontalAlignment="Stretch">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <!-- Street -->
                <Label Content="Street" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"/>
                <TextBox x:Name="tbxStreet"  Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3" Margin="2"/>

                <!-- Labels -->
                <Label Content="City" Grid.Row="1" Grid.Column="1" HorizontalAlignment="Center"/>
                <Label Content="State" Grid.Row="1" Grid.Column="2" HorizontalAlignment="Center"/>
                <Label Content="Zip Code" Grid.Row="1" Grid.Column="3" HorizontalAlignment="Center"/>

                <!-- Inputs -->
                <TextBox x:Name="tbxCity" Grid.Row="2" Grid.Column="1" Margin="2,2,4,2"/>
                <TextBox x:Name="tbxState" Grid.Row="2" Grid.Column="2" Margin="2,2,4,2"/>
                <TextBox x:Name="tbxZipCode" Grid.Row="2" Grid.Column="3" Margin="2,2,4,2"/>
            </Grid>
        </Grid>
        
        <!-- Buttons -->
        <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,20,0,0">

            <Button x:Name="btnAdd" Content="Add" Width="100" Margin="10, 0" Click="btnAdd_Click"/>
            <Button x:Name="btnRemove" Content="Remove" Width="100" Margin="10, 0" Click="btnRemove_Click"/>
            <Button x:Name="btnUpdate" Content="Update" Width="100" Margin="10, 0" Click="btnUpdate_Click"/>
        </StackPanel>
        
        <!-- Listbox -->
        <ListBox Grid.Row="3" x:Name="lbxorders" Margin="0,4,0,0"/>
    </Grid>
</Window>
