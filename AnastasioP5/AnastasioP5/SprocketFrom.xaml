<Window x:Class="AnastasioP5.SprocketFrom"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AnastasioP5"
        mc:Ignorable="d"
        Title="SprocketFrom"
        Height="450"
        Width="800"
        SizeToContent="WidthAndHeight">
    <!-- Form -->
    <Grid HorizontalAlignment="Center"
          VerticalAlignment="Center"
          Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                       Text="Sprocket Form"
                       FontSize="22"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>

        <!-- Inputs -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="250"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="35"/>
                <RowDefinition Height="35"/>
                <RowDefinition Height="35"/>
                <RowDefinition Height="35"/>
            </Grid.RowDefinitions>

            <Label Content="Item ID:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"/>
            <TextBox x:Name="tbxItemID" Grid.Row="0" Grid.Column="1" Margin="4"/>
            <Label Content="Item Type:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center"/>
            <ComboBox x:Name="cbxItemType"  Grid.Row="1" Grid.Column="1" SelectedIndex="0" Margin="4">
                <ComboBoxItem Content="Steel"/>
                <ComboBoxItem Content="Aluminum"/>
                <ComboBoxItem Content="Plastic"/>
            </ComboBox>
            <Label Content="Teeth:" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center"/>
            <TextBox x:Name="tbxNumTeeth"  Grid.Row="2" Grid.Column="1" Margin="4"/>
            <Label Content="Items:" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center"/>
            <TextBox x:Name="tbxNumItems"  Grid.Row="3" Grid.Column="1" Margin="4"/>
        </Grid>

        <!-- Buttons -->
        <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,20,0,0">
            <Button x:Name="btnSubmit" Content="Submit" Width="100" Margin="10,0" Click="btnSubmit_Click"/>
            <Button x:Name="btnCancel" Content="Cancel" Width="100" Margin="10,0" Click="btnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
